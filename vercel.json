{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "client.venuesv.com"
        }
      ],
      "destination": "/client.html"
    },
    {
      "source": "/((?!api|_next|_vercel|privacy|terms|subscribe|accept-invite|icon.png|js|client.html).*)",
      "has": [
        {
          "type": "host",
          "value": "client.venuesv.com"
        }
      ],
      "destination": "/client.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/subscribe",
      "destination": "/subscribe.html"
    },
    {
      "source": "/accept-invite",
      "destination": "/accept-invite.html"
    },
    {
      "source": "/client",
      "destination": "/client.html"
    },
    {
      "source": "/dashboard",
      "destination": "/client.html"
    },
    {
      "source": "/app",
      "destination": "/client.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}