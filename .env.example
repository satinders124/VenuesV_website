# Vercel Environment Variables — set these in Project Settings > Environment Variables.
# Never put SUPABASE_SERVICE_ROLE_KEY, STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET in public/ files.

# Public production site URL, without a trailing slash.
SITE_URL=https://venuesv.com

# Same Supabase project used by the Expo app.
SUPABASE_URL=https://nzicfhnnrbiilijmichh.supabase.co

# Supabase Dashboard > Project Settings > API > service_role (secret) key.
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Stripe Dashboard > Developers > API keys > Secret key.
STRIPE_SECRET_KEY=sk_live_replace_me

# Stripe Dashboard > Products > $19.95 AUD weekly recurring Price ID.
STRIPE_WEEKLY_PRICE_ID=price_replace_me

# Stripe Dashboard > Developers > Webhooks > Signing secret for
# https://venuesv.com/api/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Comma-separated browser origins allowed to call /api routes. The native Expo app
# has no browser Origin header; this list protects browser requests only.
ALLOWED_ORIGINS=https://venuesv.com,https://www.venuesv.com
